{
  "name": "armexam-terminal",
  "version": "1.0.0",
  "description": "ArmExam Exam Terminal — Kiosk Mode",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5174 && electron . --dev\"",
    "build:ui": "vite build",
    "dist": "npm run build:ui && electron-builder"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "vite": "^6.4.1",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "am.armexam.terminal",
    "productName": "ArmExam Terminal",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
