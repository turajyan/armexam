{
  "name": "armexam-terminal",
  "version": "1.0.0",
  "description": "ArmExam Exam Terminal — Kiosk Mode",
  "main": "main.cjs",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5174 && electron . --dev\"",
    "build:ui": "vite build",
    "dist": "npm run build:ui && electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.1.6",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "am.armexam.terminal",
    "productName": "ArmExam Terminal",
    "directories": { "output": "dist-electron" },
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  }
}
