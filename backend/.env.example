# ── Database ─────────────────────────────────────────────────────────────────
# Local: docker run -d --name armexam_db -e POSTGRES_USER=armexam \
#   -e POSTGRES_PASSWORD=armexam_pass -e POSTGRES_DB=armexam \
#   -p 5432:5432 postgres:16-alpine
DATABASE_URL="postgresql://armexam:armexam_pass@localhost:5432/armexam"
PORT=3001

# ── Admin auth ────────────────────────────────────────────────────────────────
ADMIN_SECRET="change-me-in-production"

# ── Media Storage ─────────────────────────────────────────────────────────────
# Local development: MinIO (docker compose up -d)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=armexam-media
S3_ACCESS_KEY=armexam
S3_SECRET_KEY=armexam_secret_123
# Public URL for reading files (no trailing slash)
# Local (same machine): direct MinIO URL
S3_PUBLIC_URL=http://localhost:9000/armexam-media
# Local (access via IP/network): route through Vite proxy
# S3_PUBLIC_URL=/minio/armexam-media

# Production (Cloudflare R2) — swap these 5 lines, zero code changes:
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=armexam-media
# S3_ACCESS_KEY=<r2_access_key>
# S3_SECRET_KEY=<r2_secret_key>
# S3_PUBLIC_URL=https://media.yourdomain.com
