generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Section {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  questions Question[]
}

model Question {
  id          Int      @id @default(autoincrement())
  type        String   // single_choice | multi_choice | multi_select | fill_blank | fill_wordbank | writing | audio | video | voice
  level       String   // A1 | A2 | B1 | B2 | C1 | C2
  sectionId   Int
  section     Section  @relation(fields: [sectionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  points      Int      @default(1)
  text        String

  // Choice questions
  options     Json?    // String[]
  correct     Json?    // Int | Int[]

  // Fill blank
  answer      String?

  // Word bank
  segments    Json?    // { type: "text"|"blank", content?: string, id?: number }[]
  wordBank    Json?    // String[]

  // Audio / Video
  audioSrc    String?
  videoSrc    String?
  maxPlays    Int?
  pauseSeconds Int?

  // Voice
  maxSeconds  Int?
  minSeconds  Int?
  maxAttempts Int?

  // Writing
  minWords    Int?
  maxWords    Int?

  status      String   @default("published")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Student {
  id             Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  passwordHash   String   @default("")
  phone          String?
  country        String   @default("")
  documentType   String   @default("passport")  // passport | id_card
  documentNumber String   @default("")
  gender         String   @default("")   // male | female | other
  level          String?  // detected level
  status         String   @default("active")
  sessionToken   String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  exams   ExamAssignment[]
  results Result[]
}

model City {
  id      Int          @id @default(autoincrement())
  name    String       @unique
  centers ExamCenter[]
}

model Admin {
  id           Int         @id @default(autoincrement())
  name         String
  email        String      @unique
  passwordHash String
  role         String      @default("moderator") // super_admin | center_admin | moderator | examiner
  centerId     Int?
  center       ExamCenter? @relation(fields: [centerId], references: [id], onDelete: SetNull)
  sessionToken String?     @unique
  status       String      @default("active")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model ExamCenter {
  id      Int    @id @default(autoincrement())
  name    String
  address String @default("")
  phone   String @default("")
  email   String @default("")
  cityId  Int
  city    City   @relation(fields: [cityId], references: [id])
  exams   Exam[]
  admins  Admin[]
}

model Exam {
  id                    Int      @id @default(autoincrement())
  title                 String
  examType              String   @default("fixed") // fixed | placement
  level                 String?  // null for placement
  duration              Int      @default(60)       // minutes
  passingScore          Int?     // percent, null for placement
  shuffle               Boolean  @default(false)
  showResults           Boolean  @default(true)
  showQuestionLevel     Boolean  @default(true)
  showQuestionPoints    Boolean  @default(true)

  // Fixed exam subpools: [{ section, count }]
  subpools              Json?

  // Placement exam
  placementTemplate     Json?    // [{ level, pointsEach, subpools: [{ section, count }] }]
  placementThresholds   Json?    // { A1: 60, A2: 60, ... }
  showPlacementThreshold Boolean @default(false)

  // Exam center & open registration
  examCenterId Int?
  examCenter   ExamCenter? @relation(fields: [examCenterId], references: [id])
  isOpen       Boolean     @default(false) // students can self-register

  status    String   @default("active")  // active | draft | archived
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedStudents ExamAssignment[]
  results          Result[]
}

model ExamAssignment {
  examId    Int
  studentId Int
  pin       String   @unique  // 8-char PIN (A-Z + 0-9) for student exam access
  createdAt DateTime @default(now())

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([examId, studentId])
}

model Result {
  id             Int      @id @default(autoincrement())
  examId         Int
  studentId      Int
  score          Int      // earned points (auto + manual)
  totalPoints    Int
  pct            Int      // 0-100
  passed         Boolean?
  answers        Json?    // { questionId: answer }
  detectedLevel  String?  // for placement exams
  levelStats     Json?    // for placement: { A1: { earned, maxPts, pct }, ... }
  submittedAt    DateTime @default(now())

  // Manual grading (writing / speaking)
  gradingStatus  String   @default("auto")  // auto | pending | graded
  manualGrades   Json?    // { [questionId]: { earnedPoints, maxPoints, status: "approved"|"partial"|"declined", notes } }
  gradedById     Int?
  gradedAt       DateTime?

  exam    Exam    @relation(fields: [examId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
}
